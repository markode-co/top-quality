# Rename this file to supabase.functions.local.env and fill in real values.
# Files ending with .local.env are already ignored by git in this repository.

# -----------------------------------------------------
# Supabase project/runtime settings
# -----------------------------------------------------
SUPABASE_URL=https://jlbblpmwwtbhqpigasax.supabase.co
SUPABASE_BUCKET=flutter-web
SUPABASE_WEB_DIR=build/web
SUPABASE_CACHE_MODE=safe-flutter

# -----------------------------------------------------
# Client/browser-safe keys

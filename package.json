{
  "name": "top-quality-web-deploy",
  "private": true,
  "version": "1.0.0",
  "description": "Deployment utilities for serving Flutter Web from Supabase Storage through an Edge Function SPA proxy.",
  "type": "commonjs",
  "scripts": {
    "firebase:web:build": "node ./scripts/build-firebase-web.cjs",
    "firebase:serve": "npx firebase-tools emulators:start --only hosting",
    "firebase:deploy": "npx firebase-tools deploy --only hosting",
    "netlify:web:build": "node ./scripts/build-netlify-web.cjs",
    "netlify:web:deploy": "npx netlify deploy --dir=build/web --prod",
    "netlify:web:prepare": "node ./scripts/prepare-netlify-web.cjs",
    "supabase:web:build": "flutter build web --release --base-href / --dart-define-from-file=supabase.functions.local.env",
    "supabase:runtime:check": "node ./scripts/check-supabase-runtime.cjs",
    "supabase:web:upload": "node ./scripts/upload-supabase-web.cjs",
    "supabase:web:deploy": "npm run supabase:web:build && npm run supabase:web:upload",
    "supabase:functions:serve:static-proxy": "supabase functions serve static-proxy --no-verify-jwt",
    "supabase:functions:deploy:static-proxy": "supabase functions deploy static-proxy --no-verify-jwt --use-api"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "firebase": "^12.10.0",
    "mime": "^2.6.0"
  },
  "devDependencies": {
    "supabase": "^2.77.0"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markode-co/top-quality.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/markode-co/top-quality/issues"
  },
  "homepage": "https://github.com/markode-co/top-quality#readme"
}
